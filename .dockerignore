# The gateway Docker image is web-only: keep the build context focused on the
# Go gateway and WebUI sources, and leave the desktop/Tauri client out.
**
!Dockerfile
!crates/
!crates/agent-gateway/
!crates/agent-gateway/**

# Never send local build/dependency artifacts into the Docker context.
crates/agent-gateway/bin/
crates/agent-gateway/web/dist/
crates/agent-gateway/web/node_modules/
